# --- Database ---
DATABASE_URL=postgresql://doingok:doingok@localhost:5432/doingok

# --- Runtime ---
NODE_ENV=development
PORT=3000

# Comma-separated list of web origins allowed by CORS (defaults to the Vite dev server)
CORS_ORIGIN=http://localhost:5173

# --- Auth ---
JWT_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production

# --- Background jobs (pg-boss) ---
# Set to "true" to run the in-process scheduler (check-in prompts, missed
# detection, token cleanup). Leave unset for tests/CI/sandbox.
ENABLE_JOBS=false

# --- Expo push notifications ---
# Default points to Expo's public push gateway; override in tests to mock.
# EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send

# --- Twilio (SMS escalation) ---
# When unset, SMS sends are logged to the console instead of calling Twilio.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15550000000
