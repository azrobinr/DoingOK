# --- Database ---
DATABASE_URL=postgresql://doingok:doingok@localhost:5432/doingok

# --- Runtime ---
NODE_ENV=development
PORT=3000

# Comma-separated list of web origins allowed by CORS (defaults to the Vite dev server)
CORS_ORIGIN=http://localhost:5173

# --- Auth ---
JWT_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production

# --- Background jobs (pg-boss) ---
# Set to "true" to run the in-process scheduler (check-in prompts, missed
# detection, token cleanup). Leave unset for tests/CI/sandbox.
ENABLE_JOBS=false

# --- GoAlert integration ---
# Base URL of the GoAlert instance. When unset, alert trigger/close and user
# provisioning become no-ops that log instead of calling GoAlert.
GOALERT_URL=http://localhost:8081
# Admin GraphQL API key, used to provision a service per user at registration.
GOALERT_API_KEY=your-goalert-api-key
